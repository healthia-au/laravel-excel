{
  "name": "healthia-au/maatwebsite-excel",
  "description": "Supercharged Excel exports and imports in Laravel. Fork of maatwebsite/excel.",
  "license": "MIT",
  "keywords": [
    "laravel",
    "php",
    "phpspreadsheet",
    "phpexcel",
    "excel",
    "csv",
    "export",
    "import",
    "batch"
  ],
  "authors": [
    {
      "name": "Patrick Brouwers",
      "email": "patrick@spartner.nl"
    }
  ],
  "require": {
    "ext-json": "*",
    "php": "^8.4",
    "phpoffice/phpspreadsheet": "^5.3",
    "illuminate/support": "^12.0||^13.0",
    "psr/simple-cache": "^1.0||^2.0||^3.0",
    "composer/semver": "^3.3"
  },
  "require-dev": {
    "orchestra/testbench": "*",
    "predis/predis": "*",
    "laravel/scout": "*"
  },
  "autoload": {
    "psr-4": {
      "Maatwebsite\\Excel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maatwebsite\\Excel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Maatwebsite\\Excel\\ExcelServiceProvider"
      ],
      "aliases": {
        "Excel": "Maatwebsite\\Excel\\Facades\\Excel"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
